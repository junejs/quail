# Database Configuration
# DATABASE_URL: Connection URL for PostgreSQL or MySQL
# - Leave empty to use embedded PGlite (default, no setup required)
# - PostgreSQL: postgres://user:password@host:port/database
# - MySQL: mysql://user:password@host:port/database
DATABASE_URL=

# Host Authentication
# Simple username/password authentication for host pages (create, host, history)
# If not set, authentication is disabled
HOST_USERNAME=
HOST_PASSWORD=

# JWT Secret (used for session tokens)
JWT_SECRET=your-super-secret-key
